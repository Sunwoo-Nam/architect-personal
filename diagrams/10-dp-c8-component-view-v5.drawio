        <mxCell id="bE1" value="① 목표 수신&#10;(관찰 유입 前 — 계획 먼저)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=0;exitY=0.5;entryX=0;entryY=0.4;" parent="lf" source="bTask" target="bPlanner" edge="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1082" y="147" /><mxPoint x="1082" y="649" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="bE2" value="② 계획 생성 호출 (thinking↑)&#10;응답: 단계 열" style="endArrow=classic;startArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=0.9;exitY=0;entryX=0;entryY=0.95;" parent="lf" source="bPlanner" target="bCloud" edge="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1315" y="560" /><mxPoint x="1660" y="560" /></Array></mxGeometry>
