        <mxCell id="bE3" value="③ 계획 봉인&#10;(재계획 시 갱신)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#14B8A6;exitX=0.3;exitY=0;entryX=0.3;entryY=1;" parent="lf" source="bPlanner" target="bPlanStore" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE4" value="④ 다음 단계 읽기&#10;(읽기 전용)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#14B8A6;exitX=1;exitY=0.6;entryX=0;entryY=0.25;" parent="lf" source="bPlanStore" target="bOrch" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE5" value="⑤ 단계 지시 + 계획 요약" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=1;exitY=0.25;entryX=0;entryY=0.25;" parent="lf" source="bOrch" target="bExec" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE6" value="⑥ 환경 스냅샷&#10;(단계 내 관찰 — 먼저)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#14B8A6;strokeWidth=2;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" parent="lf" source="bEnv" target="bObs" edge="1">
