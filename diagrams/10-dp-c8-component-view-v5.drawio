        <mxCell id="bE9" value="⑨ 행동 결정 → 실행" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=0.25;exitY=1;entryX=1;entryY=0.3;" parent="lf" source="bExec" target="bAct" edge="1">
