        <mxCell id="bE10" value="⑩ 환경 조작 → ⑥ 재관찰&#10;(단계 미니 루프 ⑥~⑩)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=0.5;exitY=1;entryX=0.55;entryY=0;" parent="lf" source="bAct" target="bEnv" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE11" value="⑪ 단계 보고:&#10;완료/실패/계획 불일치" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=0;exitY=0.75;entryX=1;entryY=0.75;" parent="lf" source="bExec" target="bOrch" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE12" value="⑫ 단계 경계 스냅샷&#10;→ 다음 단계(④)" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#14B8A6;exitX=0.3;exitY=0;entryX=0.5;entryY=1;" parent="lf" source="bOrch" target="bCkpt" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE13" value="⑬ 재계획: 실패 K회 · 불일치 (조건부)" style="endArrow=classic;html=1;rounded=0;dashed=1;fontSize=10;strokeColor=#444444;exitX=0;exitY=0.35;entryX=1;entryY=0.35;" parent="lf" source="bOrch" target="bPlanner" edge="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bE14" value="⑭ 전체 완료 보고" style="endArrow=classic;html=1;rounded=0;fontSize=10;strokeColor=#444444;exitX=1;exitY=0.06;entryX=1;entryY=0.75;" parent="lf" source="bOrch" target="bTask" edge="1">
